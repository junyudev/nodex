# Copy this file to `.github/act/prepare-release.secrets.local` when you need
# to provide explicit secrets for `act`. The local file stays untracked because
# `*.local` is already ignored in the repo.
#
# `GITHUB_TOKEN` is optional for the local prepare job. The wrapper script will
# try to append `gh auth token` automatically when GitHub CLI is authenticated.
# Add it here only when you need to override that behavior or when `gh` is not
# available in your shell.
GITHUB_TOKEN=ghp_replace_me
