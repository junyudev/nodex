{
  "name": "nodex",
  "version": "0.1.1",
  "description": "SQLite-based kanban board for managing coding agents",
  "private": false,
  "main": "out/main/index.js",
  "bin": {
    "nodex": "./bin/nodex.mjs"
  },
  "files": [
    "bin",
    "out",
    "src",
    "electron.vite.config.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "sync:icons": "bun run scripts/sync-app-icons.ts",
    "dev": "bun run sync:icons && electron-vite dev",
    "build": "bun run sync:icons && electron-vite build",
    "release:local": "bun run build && electron .",
    "package": "bun run build && electron-builder --mac",
    "package:all": "bun run build && electron-builder -mwl",
    "release": "bun run build && electron-builder --mac --publish always",
    "tokens:vscode:generate": "bun run scripts/generate-vscode-theme-vars.ts",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint src/",
    "lint:tailwind:fix": "ESLINT_BETTER_TAILWIND=1 eslint src/ --fix",
    "postinstall": "electron-builder install-app-deps && (chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true)"
  },
  "dependencies": {
    "@blocknote/code-block": "0.47.1",
    "@blocknote/core": "0.47.1",
    "@blocknote/react": "0.47.1",
    "@blocknote/shadcn": "0.47.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@excalidraw/excalidraw": "^0.18.0",
    "@hono/node-server": "^1.19.11",
    "@pierre/diffs": "^1.0.11",
    "@tanstack/react-form": "^1.28.4",
    "agentation": "^2.3.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ghostty-web": "^0.4.0",
    "hono": "^4.12.5",
    "katex": "^0.16.38",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-harden": "^1.1.5",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "smol-toml": "^1.4.2",
    "streamdown": "2.0.0-canary.2",
    "tailwind-merge": "^3.5.0",
    "tldts": "^7.0.25"
  },
  "devDependencies": {
    "@tailwindcss/node": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.0"
  },
  "patchedDependencies": {
    "@blocknote/core@0.47.1": "patches/@blocknote%2Fcore@0.47.1.patch",
    "@blocknote/react@0.47.1": "patches/@blocknote%2Freact@0.47.1.patch"
  }
}
