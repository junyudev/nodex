{
  "name": "nodex",
  "version": "0.1.5",
  "description": "Block-based Agent Orchestrator",
  "private": false,
  "packageManager": "bun@1.3.10",
  "main": "out/main/index.js",
  "bin": {
    "nodex": "./bin/nodex.mjs"
  },
  "files": [
    "bin",
    "out",
    "src",
    "electron.vite.config.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "sync:icons": "bun run scripts/sync-app-icons.ts",
    "release:prepare": "bun run scripts/release-changelog.ts prepare --",
    "release:prepare:act": "bash scripts/run-prepare-release-act.sh",
    "release:prepare:act:list": "bash scripts/run-prepare-release-act.sh --list",
    "release:notes": "bun run scripts/release-changelog.ts extract --",
    "release:cask": "bun run scripts/generate-homebrew-cask.ts --",
    "release:cut": "bun run scripts/release-cut.ts --",
    "release:cut:patch": "bun run release:cut -- patch",
    "release:cut:minor": "bun run release:cut -- minor",
    "release:cut:major": "bun run release:cut -- major",
    "release:patch": "bun pm version patch --no-git-tag-version && bun run release:prepare",
    "release:minor": "bun pm version minor --no-git-tag-version && bun run release:prepare",
    "release:major": "bun pm version major --no-git-tag-version && bun run release:prepare",
    "dev": "bun run sync:icons && electron-vite dev",
    "build": "bun run sync:icons && electron-vite build",
    "release:local": "bun run build && electron .",
    "package": "bun run package:mac",
    "package:mac": "bun run build && electron-builder --mac --publish never",
    "package:mac:arm64": "bun run build && electron-builder --mac dmg zip --arm64 --publish never",
    "package:mac:x64": "bun run build && electron-builder --mac dmg zip --x64 --publish never",
    "package:all": "bun run build && electron-builder -mwl",
    "release": "bun run build && electron-builder --mac --publish always",
    "tokens:vscode:generate": "bun run scripts/generate-vscode-theme-vars.ts",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint src/",
    "lint:tailwind:fix": "ESLINT_BETTER_TAILWIND=1 eslint src/ --fix",
    "postinstall": "electron-builder install-app-deps && (chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true)"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "better-sqlite3": "^12.8.0",
    "hono": "^4.12.5",
    "node-pty": "^1.1.0",
    "smol-toml": "^1.4.2"
  },
  "devDependencies": {
    "@blocknote/code-block": "0.47.1",
    "@blocknote/core": "0.47.1",
    "@blocknote/react": "0.47.1",
    "@blocknote/shadcn": "0.47.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/node": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@excalidraw/excalidraw": "^0.18.0",
    "@pierre/diffs": "^1.0.11",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.3",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@streamdown/cjk": "1.0.2",
    "@streamdown/code": "1.1.0",
    "@streamdown/math": "1.0.2",
    "@streamdown/mermaid": "1.0.2",
    "@tanstack/react-form": "^1.28.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^5.1.4",
    "agentation": "^2.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "ghostty-web": "^0.4.0",
    "katex": "^0.16.38",
    "lucide-react": "^0.577.0",
    "minisearch": "^7.1.2",
    "tailwindcss": "^4.2.1",
    "tailwind-merge": "^3.5.0",
    "tldts": "^7.0.25",
    "tw-animate-css": "^1.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-test-renderer": "19.2.4",
    "remark-breaks": "^4.0.0",
    "streamdown": "2.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.0"
  },
  "patchedDependencies": {
    "@blocknote/core@0.47.1": "patches/@blocknote%2Fcore@0.47.1.patch",
    "@blocknote/react@0.47.1": "patches/@blocknote%2Freact@0.47.1.patch"
  }
}
